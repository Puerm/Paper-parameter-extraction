{
  "permissions": {
    "allow": [
      "Bash(npx gsd-core *)",
      "Read(.planning/*)",
      "Write(.planning/*)",
      "Read(STATE.md)",
      "Write(STATE.md)",
      "mcp__codegraph__codegraph_context",
      "mcp__codegraph__codegraph_search",
      "mcp__codegraph__codegraph_explore",
      "Bash(npm run *)",
      "Bash(npx eslint *)",
      "mcp__Claude_Preview__preview_start",
      "Bash(python3 .claude/skills/ui-ux-pro-max/scripts/search.py \"AI research tool playful vibrant creative\" --design-system -f markdown -p \"PaperParams\")",
      "Bash(npm --prefix frontend run build)",
      "Bash(docker compose *)",
      "Bash(docker --version)",
      "Bash(netstat -ano)",
      "Bash(powershell.exe -Command \"Get-NetTCPConnection -LocalPort 3000 -ErrorAction SilentlyContinue | Select-Object LocalPort, OwningProcess\")",
      "Bash(python3 .claude/skills/ui-ux-pro-max/scripts/search.py \"academic research paper extraction tool playful warm\" --design-system -p \"PaperParams\" -f markdown)",
      "Bash(python3 -c \"import sys; sys.path.insert\\(0, '.claude/skills/ui-ux-pro-max/scripts'\\); from search import main; main\\(\\)\" \"academic research paper\" --design-system -p \"PaperParams\")",
      "Bash(python3 -c ' *)",
      "Bash(python3 .claude/skills/ui-ux-pro-max/scripts/search.py \"academic research\" --domain style)",
      "Bash(python3 .claude/skills/ui-ux-pro-max/scripts/search.py \"test\")",
      "Bash(echo \"EXIT CODE: $?\")",
      "Bash(python3 -c \"import sys; sys.path.insert\\(0, '.claude/skills/ui-ux-pro-max/scripts'\\); from core import DATA_DIR; print\\(DATA_DIR\\)\")",
      "Bash(echo \"FAILED with $?\")",
      "Bash(python3 -u -X utf8 .claude/skills/ui-ux-pro-max/scripts/search.py \"test\" -d style)",
      "Bash(echo \"FAILED $?\")",
      "Bash(PYTHONIOENCODING=utf-8 python3 -X utf8 .claude/skills/ui-ux-pro-max/scripts/search.py \"academic research tool\" --design-system -p \"PaperParams\" -f markdown)",
      "Bash(echo \"EXIT: $?\")"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(.secrets)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"C:/Program Files/nodejs/node.exe\" \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/gsd-check-update.js"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/gsd-session-state.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "\"C:/Program Files/nodejs/node.exe\" \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/gsd-context-monitor.js",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "\"C:/Program Files/nodejs/node.exe\" \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/gsd-read-injection-scanner.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/gsd-graphify-update.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/gsd-phase-boundary.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"C:/Program Files/nodejs/node.exe\" \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/gsd-prompt-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"C:/Program Files/nodejs/node.exe\" \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/gsd-read-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"C:/Program Files/nodejs/node.exe\" \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/gsd-workflow-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"C:/Program Files/nodejs/node.exe\" \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/gsd-worktree-path-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/gsd-validate-commit.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"C:/Program Files/nodejs/node.exe\" \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/gsd-context-monitor.js",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"C:/Program Files/nodejs/node.exe\" \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/gsd-context-monitor.js",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"C:/Program Files/nodejs/node.exe\" \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/gsd-context-monitor.js",
            "timeout": 10
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": "config.json",
        "hooks": [
          {
            "type": "command",
            "command": "\"C:/Program Files/nodejs/node.exe\" \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/gsd-config-reload.js",
            "timeout": 8
          }
        ]
      }
    ]
  },
  "worktree": {}
}
